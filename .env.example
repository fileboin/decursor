# =============================================================================
# Decursor — Environment Variables
# Kopiraj u .env i popuni vrijednosti.
# Varijable bez default-a ili sa primjerom su obavezne; ostale su opcionalne.
# =============================================================================


# ── Server ────────────────────────────────────────────────────────────────────

# HTTP port na kome server sluša.
# Default: 3000
PORT=3000

# API ključ koji svaki klijent mora slati kao header "x-decursor-key: VALUE".
# Ostavi prazno (ili ne postavljaj) da onemogućiš autentikaciju.
DECURSOR_ACCESS_KEY=

# Direktorij izložen filesystem MCP serveru, file API-ju i shell komandama.
# Default: process.cwd() — radni direktorij procesa pri startu.
MCP_WORKSPACE_DIR=


# ── OpenRouter / AI Providers ─────────────────────────────────────────────────

# OpenRouter API ključ (obavezno za korišćenje OpenRouter modela).
# Dobij na: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Javni URL servera — šalje se kao HTTP-Referer header u OpenRouter zahtjevima.
# Postavi na tvoj deployment URL (Render, Hetzner VPS, itd.)
# Default: http://localhost:3000
PUBLIC_URL=https://decursor.onrender.com

# Default Ollama base URL (može se mijenjati per-sesiji u UI-u).
# Default: http://localhost:11434
# Primjer: https://ollama.tvojdomain.com
OLLAMA_URL=


# ── MCP — Filesystem ──────────────────────────────────────────────────────────
# Nema posebnih env varijabli. Koristi MCP_WORKSPACE_DIR (gore).
# Server: @modelcontextprotocol/server-filesystem (npm, uključen u dependencies)


# ── MCP — Git ─────────────────────────────────────────────────────────────────
# Nema posebnih env varijabli. Koristi MCP_WORKSPACE_DIR kao --repository arg.
# Server: mcp-server-git (Python) — instalira se sa: pip3 install mcp-server-git
# Spawnuje se kao: python3 -m mcp_server_git --repository <MCP_WORKSPACE_DIR>


# ── MCP — GitHub ──────────────────────────────────────────────────────────────

# GitHub Personal Access Token za @modelcontextprotocol/server-github.
# Bez ovog tokena GitHub MCP server prikazuje se kao "not configured".
# Kreiraj na: https://github.com/settings/tokens
# Preporučeni scopes: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=


# ── MCP — Memory ──────────────────────────────────────────────────────────────

# Putanja do .jsonl fajla za perzistentno pamćenje između sesija.
# Default: <MCP_WORKSPACE_DIR>/data/memory.jsonl
MEMORY_FILE_PATH=


# ── MCP — Brave Search ────────────────────────────────────────────────────────

# Brave Search API ključ za @modelcontextprotocol/server-brave-search.
# Bez ovog ključa Web Search MCP server prikazuje se kao "not configured".
# Kreiraj na: https://api.search.brave.com/app/keys
BRAVE_API_KEY=


# ── MCP — Postgres ────────────────────────────────────────────────────────────

# Primarna Postgres konekcija (obavezna za Postgres MCP server).
# Radi sa Neon, Supabase, self-hosted Postgres, Render Postgres, itd.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Dodatne Postgres konekcije (sve opcionalne) — svaka dobija poseban MCP server
# u Manage MCP panelu. Dostupni indeksi: 2–9.
# _NAME je opcionalni display name (default: "Postgres N").
# POSTGRES_2_URL=postgresql://user:password@staging-host:5432/dbname
# POSTGRES_2_NAME=Staging

# POSTGRES_3_URL=postgresql://user:password@test-host:5432/testdb
# POSTGRES_3_NAME=Test

# POSTGRES_4_URL=
# POSTGRES_4_NAME=

# POSTGRES_5_URL=
# POSTGRES_5_NAME=

# POSTGRES_6_URL=
# POSTGRES_6_NAME=

# POSTGRES_7_URL=
# POSTGRES_7_NAME=

# POSTGRES_8_URL=
# POSTGRES_8_NAME=

# POSTGRES_9_URL=
# POSTGRES_9_NAME=

# Write mode je isključen po defaultu (sve konekcije su read-only).
# Uključuje se per-konekciju u Manage MCP panelu.
# Svaki write upit (INSERT/UPDATE/DELETE/DDL) zahtijeva eksplicitnu potvrdu u UI-u.


# ── MCP — Telegram ────────────────────────────────────────────────────────────

# Telegram bot token — dobij od @BotFather na Telegram-u.
# Bez ovog tokena Telegram MCP server prikazuje se kao "not configured".
TELEGRAM_BOT_TOKEN=

# Chat ID koji prima automatske Telegram notifikacije pri kritičnim greškama servera.
# Koristi isti bot kao TELEGRAM_BOT_TOKEN.
# Kako naći chat_id: pošalji poruku botu, pa pozovi:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# Trigeri: uncaughtException, unhandledRejection, port bind error, DB nedostupna pri startu.
# Ostavi prazno da isključiš error notifikacije.
TELEGRAM_ERROR_CHAT_ID=


# ── MCP — Fetch/HTTP ─────────────────────────────────────────────────────────

# Dozvoljeni domeni za http_request tool (comma-separated, bez protokola ili putanje).
# Primjer: HTTP_ALLOWED_DOMAINS=api.openai.com,api.github.com,httpbin.org
# Prazno ili nepostavljeno = svi domeni su dozvoljeni.
HTTP_ALLOWED_DOMAINS=

# Maksimalna veličina HTTP response-a koji se prosleđuje modelu (u KB).
# Ako response prelazi limit, biće skraćen sa porukom modelu.
# Default: 50 (= 50 KB)
HTTP_MAX_RESPONSE_KB=50


# ── MCP — Terminal ────────────────────────────────────────────────────────────
# Nema posebnih env varijabli. Terminal MCP uvijek zahtijeva eksplicitnu
# potvrdu korisnika prije izvršavanja svake komande — ovo se ne može isključiti.


# ── Audit log ─────────────────────────────────────────────────────────────────

# Putanja do audit log fajla.
# Loguje: shell komande (proposed/allowed/denied), HTTP pozive, Telegram akcije,
#         kritične greške servera.
# Default: <process.cwd()>/logs/exec-audit.log
# Primjer: EXEC_AUDIT_LOG=/var/log/decursor/exec-audit.log
EXEC_AUDIT_LOG=
