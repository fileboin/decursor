# Required for OpenRouter models
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: default Ollama base URL (can also be set per-session in the UI)
# Example: https://ollama.yourdomain.com
OLLAMA_URL=

# Optional: used in OpenRouter request headers, set to your Render URL once deployed
PUBLIC_URL=https://decursor.onrender.com

PORT=3000

# Access key for all /api/* endpoints.
# Every client must send header "x-decursor-key: VALUE".
# Leave blank (or omit) to disable authentication.
DECURSOR_ACCESS_KEY=

# Directory exposed to the MCP filesystem server.
# Defaults to the server's working directory (process.cwd()) when not set.
MCP_WORKSPACE_DIR=

# ── Faza 2: MCP serveri ──────────────────────────────────────────────────────

# GitHub MCP server — @modelcontextprotocol/server-github
# Isti PAT koji koristiš u GitHub modalu u UI-u.
# Bez ovog tokena GitHub MCP server prikazuje se kao "not configured".
GITHUB_PERSONAL_ACCESS_TOKEN=

# Brave Search MCP server — @modelcontextprotocol/server-brave-search
# Dobij ključ na: https://api.search.brave.com/app/keys
# Bez ovog ključa Web Search MCP server prikazuje se kao "not configured".
BRAVE_API_KEY=

# Memory MCP server — @modelcontextprotocol/server-memory
# Putanja do .jsonl fajla za perzistentno pamćenje.
# Default: <MCP_WORKSPACE_DIR>/data/memory.jsonl
MEMORY_FILE_PATH=

# Git MCP server — mcp-server-git (Python, instalira se via pip3)
# Spawnuje se kao: python3 -m mcp_server_git --repository <MCP_WORKSPACE_DIR>
# Nema dodatnih env varijabli; koristi isti workspace dir kao filesystem.
# Na Render-u dodaj u Build Command: pip3 install mcp-server-git

# ── Faza 3: Postgres MCP ─────────────────────────────────────────────────────

# Primarna Postgres konekcija (obavezna za Postgres MCP server).
# Radi sa bilo kojim providerom: Neon, Supabase, self-hosted, Render Postgres...
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Dodatne konekcije (opciono) — svaka dobija poseban entry u Manage MCP panelu.
# Dodaj _2, _3, ... do _9.
# POSTGRES_2_URL=postgresql://user:password@staging-host:5432/dbname
# POSTGRES_2_NAME=Staging

# POSTGRES_3_URL=postgresql://user:password@test-host:5432/testdb
# POSTGRES_3_NAME=Test

# Write mode je isključen po defaultu (read-only). Uključuje se per-konekciju
# u Manage MCP panelu. Svaki write upit zahtijeva eksplicitnu potvrdu u UI-u.
