# Required for OpenRouter models
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: default Ollama base URL (can also be set per-session in the UI)
# Example: https://ollama.yourdomain.com
OLLAMA_URL=

# Optional: used in OpenRouter request headers, set to your Render URL once deployed
PUBLIC_URL=https://decursor.onrender.com

PORT=3000

# Access key for all /api/* endpoints.
# Every client must send header "x-decursor-key: VALUE".
# Leave blank (or omit) to disable authentication.
DECURSOR_ACCESS_KEY=
